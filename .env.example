# Copy to .env and fill in values.

# PostgreSQL (Railway: use the DATABASE_URL from your Postgres plugin)
DATABASE_URL="postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=public"

# Auth.js / NextAuth — generate with: openssl rand -base64 32
AUTH_SECRET="replace-with-random-secret"

# App URL (local dev)
AUTH_URL="http://localhost:3000"

# Optional: public URL for client-side links (same as AUTH_URL in many setups)
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Optional: seed password for prisma/seed.ts (default: changeme)
# SEED_PASSWORD="changeme"

# Minimum rest between shifts in minutes (swap / assignment validation)
# MIN_REST_MINUTES=480
