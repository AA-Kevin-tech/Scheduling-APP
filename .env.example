# Copy to .env and fill in values.

# PostgreSQL (Railway: use the DATABASE_URL from your Postgres plugin)
DATABASE_URL="postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=public"

# Auth.js / NextAuth — generate with: openssl rand -base64 32
AUTH_SECRET="replace-with-random-secret"

# App URL (local dev)
AUTH_URL="http://localhost:3000"

# Optional: public URL for client-side links (same as AUTH_URL in many setups)
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Transactional email (Resend) — password reset and scheduling notifications
# RESEND_API_KEY="re_..."
# EMAIL_FROM="Scheduling <alerts@yourdomain.com>"

# SMS alerts (Twilio) — optional; employees/managers opt in under profile/settings
# TWILIO_ACCOUNT_SID="AC..."
# TWILIO_AUTH_TOKEN="..."
# Use either a sender number or a Messaging Service SID:
# TWILIO_PHONE_NUMBER="+1..."
# TWILIO_MESSAGING_SERVICE_SID="MG..."

# Optional: seed passwords for prisma/seed.ts
# SEED_ADMIN_ACCOUNT_PASSWORD — admin@seed.local only (default set in seed.ts if unset)
# SEED_PASSWORD / SEED_ADMIN_PASSWORD — manager + demo employees (default: changeme)
# SEED_PASSWORD="changeme"
# SEED_ADMIN_PASSWORD="changeme"

# Minimum rest between shifts in minutes (swap / assignment validation)
# MIN_REST_MINUTES=480

# IANA time zone for the manager schedule board and “create shift” defaults (e.g. America/Chicago)
# NEXT_PUBLIC_DEFAULT_SCHEDULE_TIMEZONE="America/Chicago"

# Time clock kiosk (/terminal): minutes before shift start employees may clock in; kiosk cookie hours; worker session after password
# TIME_CLOCK_EARLY_MINUTES=30
# TIME_CLOCK_KIOSK_HOURS=24
# TIME_CLOCK_WORKER_SESSION_MINUTES=30
# Minutes after scheduled start before a clock-in counts as “late” (manager alert)
# TIME_CLOCK_LATE_AFTER_MINUTES=1
# Minutes after start before “missing clock-in” while shift is still open
# TIME_CLOCK_MISSING_IN_AFTER_MINUTES=15
# Warn when worked minutes reach this % of weekly HourLimit cap (clock-out alert, once per week)
# TIME_CLOCK_WEEKLY_CAP_WARN_PERCENT=90

# QuickBooks Online (Intuit Developer app — Admin → Integrations in the app)
# INTUIT_CLIENT_ID="..."
# INTUIT_CLIENT_SECRET="..."
# Optional: override callback URL (default: {AUTH_URL}/api/integrations/quickbooks/callback)
# INTUIT_REDIRECT_URI="http://localhost:3000/api/integrations/quickbooks/callback"
# Optional: space-separated OAuth scopes (default: com.intuit.quickbooks.accounting)
# INTUIT_SCOPES="com.intuit.quickbooks.accounting"
# Use live QuickBooks API hostname (unset = sandbox API for development keys)
# INTUIT_USE_PRODUCTION="true"
