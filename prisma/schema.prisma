// Scheduling app — PostgreSQL (Railway + local)

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ——— Auth.js (Prisma adapter) ———

model User {
  id                String    @id @default(cuid())
  name              String?
  firstName         String?
  lastName          String?
  email             String    @unique
  emailVerified     DateTime?
  image             String?
  passwordHash      String?
  role              UserRole  @default(EMPLOYEE)
  /// Bumped on password reset; JWT must match or session is cleared.
  credentialVersion Int       @default(0)
  /// Send scheduling alerts to this address (same as login email).
  notifyEmail       Boolean   @default(true)
  notifySms         Boolean   @default(false)
  /// When the user consented to SMS; required for outbound texts.
  smsOptInAt        DateTime?
  /// Best mobile for SMS when this user has no Employee row (e.g. manager-only). E.164 when saved.
  phoneE164         String?

  accounts      Account[]
  sessions      Session[]
  notifications Notification[]
  auditLogs     AuditLog[] @relation("AuditActor")
  /// Admin who last completed QuickBooks OAuth (org-wide integration).
  quickBooksConnections QuickBooksConnection[] @relation("QuickBooksConnectedBy")

  employee Employee?
  /// Invites sent to prospective employees (self-onboarding).
  sentEmployeeInvites EmployeeInvite[]
  /// Venues this manager may schedule and view (managers without rows fall back to EmployeeLocation).
  managerLocations ManagerLocation[]
  /// HR / compliance documents uploaded from admin user edit (binary stored in Postgres).
  uploadedEmployeeFiles EmployeeFile[] @relation("EmployeeFileUploadedBy")
}

/// Single-tenant QuickBooks Online link (OAuth tokens for payroll/time export).
model QuickBooksConnection {
  id                   String   @id @default("singleton")
  realmId              String   @unique
  accessToken          String   @db.Text
  refreshToken         String   @db.Text
  accessTokenExpiresAt DateTime
  scope                String?
  companyName          String?
  connectedByUserId    String?
  connectedAt          DateTime @default(now())
  updatedAt            DateTime @updatedAt

  connectedBy User? @relation("QuickBooksConnectedBy", fields: [connectedByUserId], references: [id], onDelete: SetNull)
}

/// Physical venue / job site (e.g. main building, annex).
model Location {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  address   String?
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  employeeLocations EmployeeLocation[]
  managerLocations  ManagerLocation[]
  departments       Department[]
  shifts            Shift[]
}

/// Manager access to a venue (scheduling, roster, shifts). Synced from user provisioning when role is MANAGER.
model ManagerLocation {
  id         String   @id @default(cuid())
  userId     String
  locationId String
  createdAt  DateTime @default(now())

  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  location Location @relation(fields: [locationId], references: [id], onDelete: Cascade)

  @@unique([userId, locationId])
}

model Account {
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([provider, providerAccountId])
}

model Session {
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@unique([identifier, token])
}

// ——— Organization ———

model Department {
  id         String   @id @default(cuid())
  locationId String
  name       String
  slug       String
  colorToken String
  sortOrder  Int      @default(0)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  location Location @relation(fields: [locationId], references: [id], onDelete: Restrict)

  zones               DepartmentZone[]
  roles               Role[]
  shifts              Shift[]
  employeeDepartments EmployeeDepartment[]
  certifications      Certification[]
  coverageRules       CoverageRule[]
  hourLimits          HourLimit[]

  @@unique([locationId, slug])
}

model DepartmentZone {
  id           String   @id @default(cuid())
  departmentId String
  name         String
  slug         String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  department    Department      @relation(fields: [departmentId], references: [id], onDelete: Cascade)
  shifts        Shift[]
  coverageRules CoverageRule[]

  @@unique([departmentId, slug])
}

/// Job role within a department (e.g. Attendant, Lead)
model Role {
  id           String   @id @default(cuid())
  departmentId String
  name         String
  slug         String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  department          Department           @relation(fields: [departmentId], references: [id], onDelete: Cascade)
  employeeDepartments EmployeeDepartment[]
  shifts              Shift[]
  hourLimits          HourLimit[]

  @@unique([departmentId, slug])
}

model Employee {
  id             String    @id @default(cuid())
  userId         String    @unique
  employeeNumber String?   @unique
  /// Contact phone (employee-editable on their profile).
  phone          String?
  /// IANA time zone (e.g. America/Chicago) for schedule display and defaults.
  timezone       String    @default("America/Chicago")
  hireDate       DateTime?
  /// When set, the profile is kept for records but excluded from scheduling and the employee app.
  archivedAt     DateTime?
  /// Internal notes visible to managers and admins only (not shown to the employee).
  managerNotes   String?   @db.Text
  compensationType CompensationType @default(HOURLY)
  hourlyRate     Decimal?  @db.Decimal(10, 2)
  annualSalary   Decimal?  @db.Decimal(12, 2)
  employmentType EmploymentType @default(FULL_TIME)
  /// When true, company holiday paid-absence and premium rules apply (if configured).
  holidayPayEligible Boolean @default(true)
  /// Bcrypt hash of time clock PIN (terminal login); set during self-onboarding or by manager/admin.
  timeClockPinHash String?
  /// HMAC-SHA256 digest for O(1) PIN resolution (legacy rows may be null until PIN is set again).
  timeClockPinLookup String?
  /// Mailing / payroll address (employee enters during onboarding when applicable).
  addressLine1 String?
  addressLine2 String?
  city         String?
  state        String?
  postalCode   String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  payrollVault EmployeePayrollVault?

  departments      EmployeeDepartment[]
  certifications   Certification[]
  shiftAssignments ShiftAssignment[]
  availability     Availability[]
  timeOffRequests  TimeOffRequest[] @relation("TimeOffEmployee")
  swapRequestsOut  SwapRequest[]    @relation("SwapRequester")
  swapRequestsIn   SwapRequest[]    @relation("SwapTarget")
  hourLimits       HourLimit[]
  locations        EmployeeLocation[]
  files            EmployeeFile[]

  /// Enforces unique kiosk PINs among rows that have a lookup digest (nulls allowed for employees without a PIN).
  @@unique([timeClockPinLookup])
}

/// Admin-uploaded documents tied to an employee (not visible in the employee app).
model EmployeeFile {
  id                 String   @id @default(cuid())
  employeeId         String
  fileName           String
  contentType        String?
  sizeBytes          Int
  data               Bytes
  description        String?  @db.Text
  uploadedByUserId   String?
  createdAt          DateTime @default(now())

  employee   Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  uploadedBy User?    @relation("EmployeeFileUploadedBy", fields: [uploadedByUserId], references: [id], onDelete: SetNull)

  @@index([employeeId])
}

/// Pending self-service onboarding link (email + token). Consumed when the employee completes signup.
model EmployeeInvite {
  id        String    @id @default(cuid())
  email     String
  /// Opaque secret from the invite URL; treat like a password reset token.
  token     String    @unique
  expiresAt DateTime
  invitedById String
  consumedAt DateTime?
  createdAt DateTime  @default(now())
  /// First time the employee hit a valid onboarding page (not necessarily submitted).
  startedAt DateTime?
  stage     EmployeeInviteStage @default(INVITED)

  employeeNumber String?
  firstName      String?
  lastName       String?
  locationIds    String[] @default([])
  assignments    Json

  invitedBy User @relation(fields: [invitedById], references: [id], onDelete: Cascade)

  @@index([email])
  @@index([stage])
}

/// Encrypted JSON blob: SSN, tax withholding, direct deposit (for future QuickBooks Payroll export).
model EmployeePayrollVault {
  id         String   @id @default(cuid())
  employeeId String   @unique
  ciphertext String   @db.Text
  iv         String
  authTag    String
  updatedAt  DateTime @updatedAt

  employee Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
}

/// Org-wide paid holiday calendar (interpret `holidayDateYmd` in the default schedule timezone).
model CompanyHoliday {
  id                    String   @id @default(cuid())
  holidayDateYmd        String
  name                  String
  workPremiumMultiplier Decimal  @default(1) @db.Decimal(4, 2)
  paidAbsenceHours      Decimal? @db.Decimal(5, 2)
  notes                 String?  @db.Text
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  @@unique([holidayDateYmd])
  @@index([holidayDateYmd])
}

/// M2M: employee ↔ department with optional role and primary flag
model EmployeeDepartment {
  id           String   @id @default(cuid())
  employeeId   String
  departmentId String
  roleId       String?
  isPrimary    Boolean  @default(false)
  createdAt    DateTime @default(now())

  employee   Employee   @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  department Department @relation(fields: [departmentId], references: [id], onDelete: Cascade)
  role       Role?      @relation(fields: [roleId], references: [id], onDelete: SetNull)

  @@unique([employeeId, departmentId])
}

model EmployeeLocation {
  id         String   @id @default(cuid())
  employeeId String
  locationId String
  isPrimary  Boolean  @default(false)
  createdAt  DateTime @default(now())

  employee Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  location Location @relation(fields: [locationId], references: [id], onDelete: Cascade)

  @@unique([employeeId, locationId])
}

model Certification {
  id           String    @id @default(cuid())
  employeeId   String
  departmentId String?
  name         String
  issuedAt     DateTime?
  expiresAt    DateTime?
  createdAt    DateTime  @default(now())

  employee   Employee    @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  department Department? @relation(fields: [departmentId], references: [id], onDelete: SetNull)
}

// ——— Scheduling ———

model Shift {
  id             String    @id @default(cuid())
  departmentId   String
  locationId     String?
  roleId         String?
  zoneId         String?
  title          String?
  startsAt       DateTime
  endsAt         DateTime
  /// When null, the shift is a manager-only draft until published.
  publishedAt    DateTime?
  recurrenceRule String?   @db.Text
  parentShiftId  String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  department Department      @relation(fields: [departmentId], references: [id], onDelete: Cascade)
  location   Location?       @relation(fields: [locationId], references: [id], onDelete: SetNull)
  role       Role?           @relation(fields: [roleId], references: [id], onDelete: SetNull)
  zone       DepartmentZone? @relation(fields: [zoneId], references: [id], onDelete: SetNull)
  parent     Shift?          @relation("ShiftSeries", fields: [parentShiftId], references: [id], onDelete: SetNull)
  children   Shift[]         @relation("ShiftSeries")

  assignments ShiftAssignment[]
}

model ShiftAssignment {
  id                    String   @id @default(cuid())
  shiftId               String
  employeeId            String
  assignedByUserId      String?
  managerOverrideReason String?  @db.Text
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  shift    Shift    @relation(fields: [shiftId], references: [id], onDelete: Cascade)
  employee Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  swapRequestsFrom SwapRequest[] @relation("SwapFromAssignment")
  swapRequestsTo   SwapRequest[] @relation("SwapToAssignment")
  /// One row per clock-in segment (e.g. return from lunch = new row).
  timePunches      ShiftTimePunch[]
}

/// Clock in / clock out segment; multiple rows per assignment are allowed (breaks).
model ShiftTimePunch {
  id                String    @id @default(cuid())
  shiftAssignmentId String
  clockInAt         DateTime
  clockOutAt        DateTime?
  clockInNote       String?   @db.Text
  clockOutNote      String?   @db.Text
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  assignment ShiftAssignment @relation(fields: [shiftAssignmentId], references: [id], onDelete: Cascade)

  @@index([shiftAssignmentId])
  @@index([clockOutAt])
}

model Availability {
  id            String    @id @default(cuid())
  employeeId    String
  dayOfWeek     Int
  startsAt      String
  endsAt        String
  effectiveFrom DateTime?
  effectiveTo   DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  employee Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@index([employeeId])
}

model TimeOffRequest {
  id          String        @id @default(cuid())
  employeeId  String
  startsAt    DateTime
  endsAt      DateTime
  reason      String?       @db.Text
  status      TimeOffStatus @default(PENDING)
  decidedById String?
  decidedAt   DateTime?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  employee Employee @relation("TimeOffEmployee", fields: [employeeId], references: [id], onDelete: Cascade)
}

/// Admin-defined calendar ranges (inclusive YMD in org schedule timezone) when employees may not request time off.
model TimeOffBlackout {
  id          String   @id @default(cuid())
  startsOnYmd String
  endsOnYmd   String
  label       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([startsOnYmd, endsOnYmd])
}

model SwapRequest {
  id                    String            @id @default(cuid())
  requesterEmployeeId   String
  targetEmployeeId      String?
  fromAssignmentId      String
  toAssignmentId        String?
  status                SwapRequestStatus @default(PENDING)
  managerNote           String?           @db.Text
  decidedByUserId       String?
  decidedAt             DateTime?
  managerOverrideReason String?           @db.Text
  createdAt             DateTime          @default(now())
  updatedAt             DateTime          @updatedAt

  requester      Employee @relation("SwapRequester", fields: [requesterEmployeeId], references: [id], onDelete: Cascade)
  target         Employee? @relation("SwapTarget", fields: [targetEmployeeId], references: [id], onDelete: SetNull)
  fromAssignment ShiftAssignment @relation("SwapFromAssignment", fields: [fromAssignmentId], references: [id], onDelete: Cascade)
  toAssignment   ShiftAssignment? @relation("SwapToAssignment", fields: [toAssignmentId], references: [id], onDelete: SetNull)
}

enum UserRole {
  ADMIN
  IT
  PAYROLL
  MANAGER
  EMPLOYEE
}

enum EmploymentType {
  FULL_TIME
  PART_TIME
}

enum CompensationType {
  HOURLY
  SALARY
}

enum TimeOffStatus {
  PENDING
  APPROVED
  DENIED
  CANCELLED
}

enum SwapRequestStatus {
  PENDING
  ACCEPTED_BY_TARGET
  REJECTED_BY_TARGET
  APPROVED_BY_MANAGER
  DENIED_BY_MANAGER
  CANCELLED
}

/// Progress through email invite onboarding (see Admin / Manager onboarding tracker).
enum EmployeeInviteStage {
  /// Invite email sent; onboarding URL not yet opened.
  INVITED
  /// Employee opened the onboarding page at least once.
  STARTED
  /// Submitted the onboarding form; user account created.
  COMPLETED
}

enum HourLimitScope {
  EMPLOYEE
  DEPARTMENT_ROLE
}

model HourLimit {
  id               String          @id @default(cuid())
  scope            HourLimitScope
  employeeId       String?
  departmentId     String?
  roleId           String?
  weeklyMaxMinutes Int?
  effectiveFrom    DateTime?
  effectiveTo      DateTime?
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt

  employee   Employee?   @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  department Department? @relation(fields: [departmentId], references: [id], onDelete: Cascade)
  role       Role?       @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@index([employeeId])
  @@index([departmentId, roleId])
}

model CoverageRule {
  id              String   @id @default(cuid())
  departmentId    String
  zoneId          String?
  minStaffCount   Int
  windowStartMins Int?
  windowEndMins   Int?
  validFrom       DateTime?
  validTo         DateTime?
  note            String?  @db.Text
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  department Department      @relation(fields: [departmentId], references: [id], onDelete: Cascade)
  zone       DepartmentZone? @relation(fields: [zoneId], references: [id], onDelete: SetNull)
}

model Notification {
  id        String    @id @default(cuid())
  userId    String
  title     String
  body      String    @db.Text
  type      String
  readAt    DateTime?
  emailSentAt DateTime?
  smsSentAt   DateTime?
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model AuditLog {
  id          String   @id @default(cuid())
  actorUserId String?
  entityType  String
  entityId    String
  action      String
  payload     Json?
  reason      String?  @db.Text
  createdAt   DateTime @default(now())

  actor User? @relation("AuditActor", fields: [actorUserId], references: [id], onDelete: SetNull)

  @@index([entityType, entityId])
  @@index([createdAt])
}
